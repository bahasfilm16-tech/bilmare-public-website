# Supabase — dapatkan dari Project Settings > API di supabase.com
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# URL Portal — isi dengan URL Vercel setelah portal client dan portal tim di-deploy
VITE_PORTAL_CLIENT_URL=https://portal-client.vercel.app
VITE_PORTAL_TIM_URL=https://portal-tim.vercel.app
